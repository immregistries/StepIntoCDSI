<?xml version="1.0" encoding="ISO-8859-1"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
    version="4.0">

	<display-name>CDSi core</display-name>

    <filter>
        <filter-name>authenticationFilter</filter-name>
        <filter-class>org.openimmunizationsoftware.cdsi.auth.AuthenticationFilter</filter-class>
    </filter>

    <servlet>
        <servlet-name>step</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.StepServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>fhir</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.FhirServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>supportingData</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.SupportingDataServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>home</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.HomeServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.LoginServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>account</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.AccountServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>logout</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.LogoutServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>tempAuth</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.TemporaryAuthSetupServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>forecast</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.ForecastServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>run</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.RunServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>fits</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.FitsServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>dataModelView</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.MainServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>dataModelViewPatient</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.PatientServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>dataModelViewCvx</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.CvxServlet</servlet-class>
    </servlet>
	<servlet>
        <servlet-name>dataModelViewAntigen</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.AntigenServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>dataModelViewVaccineGroup</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.VaccineGroupServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>dataModelViewSchedule</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.ScheduleServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>dataModelViewLiveVirusConflict</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.dataModelView.LiveVirusConflictServlet</servlet-class>
    </servlet>	<servlet>
        <servlet-name>sandbox</servlet-name>
        <servlet-class>org.openimmunizationsoftware.cdsi.servlet.SandboxServlet</servlet-class>
    </servlet>   
    
    <servlet-mapping>
        <servlet-name>forecast</servlet-name>
        <url-pattern>/forecast</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>run</servlet-name>
        <url-pattern>/run</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>step</servlet-name>
        <url-pattern>/step</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>fhir</servlet-name>
        <url-pattern>/fhir/*</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>step</servlet-name>
        <url-pattern>/fv/step</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>fits</servlet-name>
        <url-pattern>/fits</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>dataModelView</servlet-name>
        <url-pattern>/dataModelView</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>dataModelViewPatient</servlet-name>
        <url-pattern>/dataModelViewPatient</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>dataModelViewCvx</servlet-name>
        <url-pattern>/dataModelViewCvx</url-pattern>
    </servlet-mapping>	 
    <servlet-mapping>
        <servlet-name>dataModelViewAntigen</servlet-name>
        <url-pattern>/dataModelViewAntigen</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>dataModelViewVaccineGroup</servlet-name>
        <url-pattern>/dataModelViewVaccineGroup</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>dataModelViewSchedule</servlet-name>
        <url-pattern>/dataModelViewSchedule</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>dataModelViewLiveVirusConflict</servlet-name>
        <url-pattern>/dataModelViewLiveVirusConflict</url-pattern>
    </servlet-mapping>
	<servlet-mapping>
        <servlet-name>sandbox</servlet-name>
        <url-pattern>/sandbox</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>supportingData</servlet-name>
        <url-pattern>/supportingData</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>home</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>account</servlet-name>
        <url-pattern>/account</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>tempAuth</servlet-name>
        <url-pattern>/temp-auth</url-pattern>
    </servlet-mapping>

    <filter-mapping>
        <filter-name>authenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
    </filter-mapping>
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

</web-app>
